# ----------------------------------------------------------------------------
# DataLab Studio environment configuration
# Copy this file to `.env` and adjust values for your local setup.
# ----------------------------------------------------------------------------

# --- PostgreSQL (consumed by docker-compose.yml and the API) ---
POSTGRES_DB=datalab
POSTGRES_USER=datalab
POSTGRES_PASSWORD=datalab
POSTGRES_PORT=5432

# --- API datasource (Spring Boot) ---
# Host/port must match the PostgreSQL service above.
DATALAB_DB_URL=jdbc:postgresql://localhost:5432/datalab
DATALAB_DB_USERNAME=datalab
DATALAB_DB_PASSWORD=datalab

# --- API server ---
DATALAB_SERVER_PORT=8080

# --- Local file storage ---
# Directory where imported raw dataset files are stored.
# Relative paths are resolved against the API working directory.
DATALAB_DATA_DIR=./data
